# Copy to .env and fill in real values, or export these in your shell.
# All examples reference these via ${env.<NAME>} in their connection blocks.
#
# DSN formats:
#   Postgres: postgresql://USER:PASS@HOST:PORT/DBNAME
#   MSSQL:    Driver={ODBC Driver 18 for SQL Server};Server=HOST,PORT;Database=DBNAME;UID=USER;PWD=PASS;TrustServerCertificate=yes

# Example 01 — CSV → Postgres
WAREHOUSE_DSN=postgresql://etl:CHANGEME@localhost:5432/betl_warehouse

# Example 02 — MSSQL reporting → Postgres OLAP
REPORTING_DSN=Driver={ODBC Driver 18 for SQL Server};Server=localhost,1433;Database=betl_reporting_src;UID=sa;PWD=CHANGEME;TrustServerCertificate=yes
OLAP_DSN=postgresql://olap:CHANGEME@localhost:5432/betl_olap_dw

# Example 03 — MSSQL legacy CRM → Postgres new CRM
LEGACY_CRM_DSN=Driver={ODBC Driver 18 for SQL Server};Server=localhost,1433;Database=betl_legacy_crm_src;UID=sa;PWD=CHANGEME;TrustServerCertificate=yes
NEW_CRM_DSN=postgresql://crm:CHANGEME@localhost:5432/betl_new_crm_dst
