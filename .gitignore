# Build outputs
build/
build-*/
.cache/
compile_commands.json

# c-build analyze() forensic artifacts
.forensics/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Toolchain artifacts
*.o
*.so
*.dylib
*.dll
*.a

# .NET build artifacts (left under tools/<proj>/ by `dotnet build` /
# restore). The actual betl-dtsx2yaml publish output lands under
# build/tools/.../out/, which the build/ rule above already covers.
bin/
obj/

# Local config / secrets
.env
.env.local

# Python helpers used during dev (not part of the engine)
__pycache__/
*.pyc

# Project-local dependency installs (libpq / libyaml / dotnet SDK /
# etc.). Populated by scripts/install-*.sh, not under source control.
deps/

.source-material/
.claude/
